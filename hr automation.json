      "parameters": {
        "jsCode": "// Get the raw output from the previous node (e.g., your LLM Chain)\nconst rawOutput = $input.item.json.text;\n\n// Use a regular expression to find and extract the JSON object.\n// This handles cases where the model wraps the JSON in markdown code blocks (```json...```) or adds extra text.\nconst jsonMatch = rawOutput.match(/\\{[\\s\\S]*\\}/);\n\nlet parsedJson = null;\n\nif (jsonMatch && jsonMatch.length > 0) {\n  const jsonString = jsonMatch[0];\n  try {\n    // Attempt to parse the cleaned JSON string.\n    parsedJson = JSON.parse(jsonString);\n  } catch (e) {\n    // If parsing fails due to an error, log it or handle it.\n    console.error('Failed to parse JSON:', e.message);\n  }\n}\n\n// Add a fallback or validation logic for a common model mistake.\n// For instance, if the job name is \"Frontend Developer\", correct it to \"Web Developer\".\nif (parsedJson && parsedJson.job === \"Frontend Developer\") {\n  parsedJson.job = \"Web Developer\";\n}\n\n// Return the parsed JSON object. If parsing failed, you can return a placeholder\n// or error object to prevent the workflow from breaking.\nif (parsedJson) {\n  return [{ json: parsedJson }];\n} else {\n  // Example of a fallback: return a \"Rejected\" status with a clear justification.\n  return [{\n    json: {\n      status: \"Rejected\",\n      justification: \"Failed to parse AI output. The response was not in a valid JSON format.\"\n    }\n  }];\n}"
      },
